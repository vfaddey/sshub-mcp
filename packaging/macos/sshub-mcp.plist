<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>sshub-mcp</string>
	<key>ProgramArguments</key>
	<array>
		<string>/opt/homebrew/bin/sshub-mcp</string>
	</array>
	<key>EnvironmentVariables</key>
	<dict>
		<key>SSHUB_MCP_HTTP_ADDR</key>
		<string>127.0.0.1:8787</string>
	</dict>
	<key>RunAtLoad</key>
	<true/>
	<key>KeepAlive</key>
	<true/>
	<key>StandardOutPath</key>
	<string>/tmp/sshub-mcp.log</string>
	<key>StandardErrorPath</key>
	<string>/tmp/sshub-mcp.err</string>
</dict>
</plist>
